{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,

    "moduleResolution": "nodenext",

    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"],
      "@generated/*": ["./src/generated/*"],
      "env": ["./src/lib/env"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
