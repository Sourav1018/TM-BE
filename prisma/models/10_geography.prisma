model Country {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  code      String   @db.Char(2)
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  states State[]

  @@map("countries")
}

model State {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  countryId String   @map("country_id") @db.Uuid
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  country Country @relation(fields: [countryId], references: [id])
  cities  City[]

  @@index([countryId])
  @@map("states")
}

model City {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  stateId   String   @map("state_id") @db.Uuid
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  state  State   @relation(fields: [stateId], references: [id])
  places Place[]

  @@index([stateId])
  @@map("cities")
}

model Place {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  cityId        String   @map("city_id") @db.Uuid
  latitude      Float
  longitude     Float
  googlePlaceId String?  @map("google_place_id")
  mapUrl        String?  @map("map_url")
  slug          String
  createdAt     DateTime @default(now()) @map("created_at")

  city      City      @relation(fields: [cityId], references: [id])
  packages  Package[]

  @@index([cityId])
  @@map("places")
}
